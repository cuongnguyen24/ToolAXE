{
  "SqlVersion": "SQL Server 2022",
  "Edition": "Developer",
  "InstanceName": "MSSQLSERVER",
  "Installers": {
    "SqlOfflinePath": "installers\\offline\\SQLServer2022Offline",
    "SsmsOfflinePath": "installers\\offline\\SSMSOffline"
  },
  "AuthenticationMode": "Mixed",
  "SaPassword": "Axe@2026#Sql",
  "SqlAdmins": [
    "BUILTIN\\Administrators"
  ],
  "ServiceAccounts": {
    "SqlServiceAccount": "NT Service\\MSSQLSERVER",
    "AgentServiceAccount": "NT Service\\SQLSERVERAGENT"
  },
  "Network": {
    "EnableTcp": true,
    "EnableNamedPipes": false,
    "TcpPort": 1433,
    "OpenFirewall": true
  },
  "Paths": {
    "DataRoot": "C:\\SQLServer",
    "UserDbData": "C:\\SQLServer\\Data",
    "UserDbLog": "C:\\SQLServer\\Log",
    "TempDbData": "C:\\SQLServer\\TempDB",
    "TempDbLog": "C:\\SQLServer\\TempDBLog",
    "Backup": "C:\\SQLServer\\Backup"
  },
  "ServerTuning": {
    "MaxServerMemoryMB": 2147483647,
    "MaxDop": 4,
    "CostThresholdForParallelism": 50
  },
  "AppLogins": [
    {
      "LoginName": "dev",
      "LoginType": "SqlLogin",
      "Password": "Dev@2026#Sql",
      "DefaultDatabase": "master",
      "ServerRoles": [
        "sysadmin"
      ]
    }
  ],
  "Databases": [
    {
      "Name": "AXE_APP",
      "CreateIfMissing": false,
      "RecoveryModel": "FULL"
    }
  ]
}
